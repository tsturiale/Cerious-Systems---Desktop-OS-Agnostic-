# Cerious Systems environment template
# Copy to .env for local runs, or provide the same names as cloud secrets.

# Runtime mode
CERIOUS_DRY_RUN=1
CERIOUS_PRICE_PROVIDER=databento

# Gateway / frontend hosting
CERIOUS_BACKEND_HOST=127.0.0.1
CERIOUS_BACKEND_PORT=8000
CERIOUS_EXCHANGE_HOST=127.0.0.1
CERIOUS_FRONTEND_HOST=127.0.0.1
CERIOUS_FRONTEND_PORT=5173
CERIOUS_GATEWAY_HTTP=http://127.0.0.1:8000
CERIOUS_GATEWAY_WS=ws://127.0.0.1:8000
CERIOUS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
VITE_CERIOUS_WS_BASE=

# Execution destination
CERIOUS_EXECUTION_DESTINATION=cerious-exchange
CERIOUS_EXCHANGE_HTTP_PORT=8011

# Databento CME feed
DATABENTO_API_KEY=
CERIOUS_CME_DATASET=GLBX.MDP3
CERIOUS_CME_SCHEMA=mbp-1
CERIOUS_CME_SYMBOLS=ES.v.0,NQ.v.0,YM.v.0,RTY.v.0,CL.v.0,GC.v.0,ZM.v.0,ZS.v.0
CERIOUS_PRICE_FEED_SYMBOLS=ES.v.0,NQ.v.0,YM.v.0,RTY.v.0,MES.v.0,MNQ.v.0,MYM.v.0,M2K.v.0,CL.v.0,GC.v.0,ZM.v.0,ZS.v.0
CERIOUS_PRICE_FEED_STYPE=continuous
CERIOUS_PRICE_FEED_STALE_MS=30000
CERIOUS_PRICE_FEED_RECONNECT_MS=5000
CERIOUS_PRICE_FEED_MAX_RECONNECT_MS=60000

# Portal/auth
CERIOUS_PORTAL_USERNAME=
CERIOUS_PORTAL_PASSWORD=
CERIOUS_ADMIN_USERNAME=ADMIN
CERIOUS_ADMIN_PASSWORD=12345678
CERIOUS_AUTH_SECRET=
CERIOUS_ENABLE_LOCAL_AUTO_LOGIN=0


# FIX Engine - C++ daemon (native/fix-engine-cpp)
FIX_MODE=sim
FIX_SENDER_COMP_ID=CERIOUS
FIX_TARGET_COMP_ID=TT_SIM
FIX_TARGET_HOST=
FIX_TARGET_PORT=0
FIX_HEARTBEAT_INTERVAL=30
FIX_VERSION=FIX.4.4
FIX_ACCOUNT=
FIX_PASSWORD=
FIX_HTTP_HOST=127.0.0.1
FIX_HTTP_PORT=8010

# Alerts
# Set dry run to 0 to send email-to-SMS alerts through SMTP.
CERIOUS_ALERT_SMTP_DRY_RUN=1
CERIOUS_ALERT_SMTP_URL=smtps://smtp.gmail.com:465
CERIOUS_ALERT_SMTP_FROM=
CERIOUS_ALERT_SMTP_USERNAME=
# Gmail SMTP requires a Gmail App Password here; normal account passwords are rejected.
CERIOUS_ALERT_SMTP_PASSWORD=
CERIOUS_ALERT_CURL_PATH=

# E2E test endpoints
CERIOUS_E2E_BASE_URL=http://127.0.0.1:5173
CERIOUS_E2E_API_URL=http://127.0.0.1:8000
